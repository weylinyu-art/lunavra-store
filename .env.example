# Firebase Authentication (client-side; required for social sign-in on /login)
# Create a Web app in Firebase Console → Project settings, copy config.
# Authentication → Sign-in method: enable Google, Facebook, and X (Twitter) as needed.
# Instagram uses Meta: enable Facebook login; the UI shows “Facebook · Instagram”.
# Authentication → Settings → Authorized domains: add your production domain (e.g. pages.dev, custom domain).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
